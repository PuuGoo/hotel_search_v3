# Tavily API Keys (up to 20, for rotation)
TAVILY_API_KEY_1=tvly-your-key-1
TAVILY_API_KEY_2=tvly-your-key-2

# Google Custom Search API Keys (up to 10, for rotation)
GO_API_KEY_1=your-google-api-key-1
GO_API_KEY_2=your-google-api-key-2
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# Session Secret (change this in production!)
SESSION_SECRET=your-secret-key-here
SESSION_MAX_AGE=86400000

# Case12 API (optional)
CASE12_API_URL=https://hotel-search-v2-api.vercel.app/api/case12
CASE12_API_KEY=

# DuckDuckGo Server
DDG_SERVER_URL=http://localhost:5001

# CORS Origins (comma-separated, leave empty for same-origin only)
CORS_ORIGINS=

# Rate Limiting
RATE_LIMIT_LOGIN_WINDOW=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_SEARCH_WINDOW=60000
RATE_LIMIT_SEARCH_MAX=30

# Logging
LOG_LEVEL=debug

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development
